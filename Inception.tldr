		},
		{
			"x": 5785.380479261227,
			"y": 2259.2204264042107,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:2Oe99TNt0pfV5feOxsOdr",
			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 2359.0546875,
				"font": "serif",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1,
				"richText": {
					"type": "doc",
					"content": [
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| Feature                       | VPS (Virtual Private Server)                                                 | Physical Server                                           "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| ---------------------- | --------------------------------------------------------------| ---------------------------------------         "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Nature**                | Virtual machine running on shared hardware           | Actual physical computer                        "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Resources**         | Assigned portion of CPU, RAM, disk                                | Full CPU, RAM, disk                                    "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Cost**                     | Cheaper, pay for what you use                                            | Expensive, full machine cost                  "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Isolation**            | Isolated from other VPS on the same host                     | Fully isolated (nothing else shares it) "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Scalability**        | Easy to resize resources (add RAM/CPU/disk)              | Harder, requires new hardware           "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Management**   | Managed through control panel or SSH                          | Fully manual, you maintain hardware|"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "| **Setup speed**     | Instant (minutes)                                                                      | Takes time (buy/setup/shipping)         "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "---------------------------------------------------------------------------------------------------------------------------------------"
								}
							]
						}
					]
				}
			},
