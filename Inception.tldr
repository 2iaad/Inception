		{
			"x": -239.78861357322376,
			"y": 3539.0111540360945,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:ove2BiA_ImNZZwzqulNC8",
			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 2616.671875,
				"font": "serif",
				"textAlign": "middle",
				"autoSize": true,
				"scale": 1,
				"richText": {
					"type": "doc",
					"content": [
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "A data center is a physical location where thousands (or millions) of servers are stored and managed."
								}
							]
						},
						{
							"type": "paragraph"
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Think of it like a warehouse of computers, connected with high-speed internet, power backup, cooling systems, and security."
								}
							]
						},
						{
							"type": "paragraph"
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Cloud providers put their servers in these data centers and then virtualize them so you can rent a piece (a VPS) remotely."
								}
							]
						}
					]
				}
			},
			"parentId": "page:page",
			"index": "aG6Pi",
			"typeName": "shape"
		},
