			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 2616.671875,
				"font": "serif",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1,
				"richText": {
					"type": "doc",
					"content": [
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "What is a Data Center?"
								}
							]
						},
						{
							"type": "paragraph"
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Location where thousands (or millions) of servers are stored and managed."
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Think of it like a warehouse of computers, connected with high-speed internet, power backup, cooling systems, and security."
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Cloud providers put their servers in these data centers and then virtualize them so you can rent a piece (a VPS) remotely."
								}
							]
						}
					]
				}
			},
			"parentId": "page:page",
			"index": "aW8cy",
			"typeName": "shape"
