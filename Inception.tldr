			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 2462.5859375,
				"font": "serif",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1,
				"richText": {
					"type": "doc",
					"content": [
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Difference between VM's & VPS:"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Location                               ->  VM's run on the personal computers --------- VPS runs on cloud's provider Data center."
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "IP                                            ->  Usually private, not accessible from the internet ------------ Public IP, accessible worldwide."
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Hardware Ownership    ->  You use your own Mac’s CPU/RAM/disk----------You rent a slice of a shared physical server."
								}
							]
						},
						{
							"type": "paragraph"
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "-> NOTE:  You can make a VM behave like VPS in terms of Network (link it with inthernet via Port forwarding)"
								}
							]
						}
					]
				}
			},
