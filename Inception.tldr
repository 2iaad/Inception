		{
			"x": 3935.4462012552303,
			"y": 3421.3462123746253,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:8CmqaQK3m5eL7ufJ1jqVn",
			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 2462.5859375,
				"text": "Difference between VM's & VPS:\nLocation                               ->  VM's run on the personal computers --------- VPS runs on cloud's provider Data center.\nIP                                            ->  Usually private, not accessible from the internet ------------ Public IP, accessible worldwide.\nHardware Ownership    ->  You use your own Mac’s CPU/RAM/disk----------You rent a slice of a shared physical server.\n\n-> NOTE:  You can make a VM behave like VPS in terms of Network (link it with inthernet via Port forwarding)",
				"font": "serif",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1
			},
			"parentId": "page:page",
			"index": "aO4th",
			"typeName": "shape"
		},
		{
			"x": 3896.111806212737,
