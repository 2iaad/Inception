		{
			"x": 1218.5448691092752,
			"y": 1447.7720975324762,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:HWwmhiws8qA3jHLHnpTCT",
			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 3762.8519976364914,
				"font": "serif",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1.7872066958228356,
				"richText": {
					"type": "doc",
					"content": [
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "what is vps  ?"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Allows you to run your services in a remote data center."
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "VPS aka DropLet. small virtual Linux machine that is provided by a large cloud service that manages"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "data centers full of servers, networking equipment, and storage systems — and rents "
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "them to you on-demand."
								}
							]
						},
						{
							"type": "paragraph"
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "So when you create a Droplet in DigitalOcean, you’re:"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Asking DigitalOcean to run a virtual machine inside one of their physical servers,"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "In a specific data center region (e.g., Frankfurt, Amsterdam, New York)."
								}
							]
						}
					]
				}
			},
